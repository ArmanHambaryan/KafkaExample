<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="20260603-order-01" author="arman">
        <createTable tableName="orders">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="dish_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="table_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="arman">
        <addColumn tableName="orders">
            <column name="items" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="3" author="arman">
        <addColumn tableName="orders">
            <column name="received_at" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="remove-dish-name-column" author="your-name">
        <dropColumn tableName="orders" columnName="dish_name"/>
    </changeSet>
    <changeSet id="add-image-url-2026-06-16" author="arman">
        <addColumn tableName="orders"> <column name="image_url" type="varchar(255)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>